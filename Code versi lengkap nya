package uts.pemdas;

import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        try (Scanner input = new Scanner(System.in)) {
            System.out.println("========================================");
            System.out.println("Program Penghitung Indeks Prestasi Semester");
            System.out.println("========================================");
            int totalMK = 0;
            boolean valid = false;
            while (!valid) {
                try {
                    System.out.print("Masukkan total mata kuliah yang diambil: ");
                    totalMK = Integer.parseInt(input.nextLine());
                    if (totalMK > 0) {
                        valid = true;
                    } else {
                        System.out.println("Jumlah mata kuliah harus positif.");
                    }
                } catch (NumberFormatException e) {
                    System.out.println("Input harus berupa angka.");
                }
            }
            IPSTR ipsCalculator = new IPSTR();
            for (int i = 1; i <= totalMK; i++) {
                System.out.println("\nData Mata Kuliah ke-" + i);
                System.out.print("Nama mata kuliah: ");
                String nama = input.nextLine();
                int sks = 0;
                valid = false;
                while (!valid) {
                    try {
                        System.out.print("Jumlah SKS: ");
                        sks = Integer.parseInt(input.nextLine());
                        if (sks > 0) {
                            valid = true;
                        } else {
                            System.out.println("SKS harus positif.");
                        }
                    } catch (NumberFormatException e) {
                        System.out.println("Input harus angka.");
                    }
                }
                System.out.print("Nilai huruf (A, A-, B+, B, B-, C+, C, D, E): ");
                String nilaiHuruf = input.nextLine().trim().toUpperCase();
                MataKulia mk = new MataKulia(nama, sks, nilaiHuruf);
                ipsCalculator.tambahMataKuliaH(mk);
            }
            ipsCalculator.tampilkanIPS();
        }
    }
}
