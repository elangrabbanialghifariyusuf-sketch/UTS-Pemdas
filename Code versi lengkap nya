package uts.pemdas;

public class MataKulia {
   private final String nama;
   private final int sks;
   private final String nilaiHuruf;
   
   public MataKulia(String nama, int sks ,String nilaiHuruf) {
       this.nama = nama;
       this.sks = sks;
       this.nilaiHuruf = nilaiHuruf.toUpperCase();
   }
   
   public String getName() {
       return nama;
    }
   
   public int getSks() {
       return sks;
   }
   
   public double getBobot() {
       return switch (nilaiHuruf) {
           case "A" -> 4.0;
           case "-A" -> 3.7;
           case "B+" -> 3.3;
           case "B" -> 3.0;
           case "C+" -> 2.7;
           case "C" -> 2.0;
           case "D" -> 1.0;
           case "E" -> 0.0;
           default -> 0.0;
       };
   }
   
   public double getNilaiMutu(){
       return getBobot()* sks;
   }
}

