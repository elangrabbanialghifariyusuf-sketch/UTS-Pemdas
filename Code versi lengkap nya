package uts.pemdas;

import java.util.ArrayList;
public class IPSTR {
    private final ArrayList<MataKulia> daftarMK;
    public IPSTR() {
        daftarMK = new ArrayList<>();
    }
    public void tambahMataKuliaH(MataKulia mk) {
        daftarMK.add(mk);
    }
    public double hitungIPSTR() {
        double totalNilaiMutu = 0;
        int totalSKS = 0;
        
        for (MataKulia mk : daftarMK) {
            totalNilaiMutu += mk.getNilaiMutu();
            totalSKS += mk.getSks();
        }
        
        if (totalSKS == 0) {
            return 0;
        }
        return totalNilaiMutu / totalSKS;
    }    
        
    public void tampilkanIPS() {
    double totalNilaiMutu = 0;
    int totalSKS = 0;

    for (MataKulia mk : daftarMK) {
        totalNilaiMutu += mk.getNilaiMutu();
        totalSKS += mk.getSks();
    }

    double ips = totalNilaiMutu / totalSKS;

    System.out.println("--------------------------------");
    System.out.println("IPS Anda = " + ips);
    }
}

